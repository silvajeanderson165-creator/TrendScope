# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (usado para assinar JWT)

# ── Database (TiDB Cloud) ─────────────────────────────────────
DATABASE_URL="mysql://SEU_USUARIO:SUA_SENHA@gateway01.us-east-1.prod.aws.tidbcloud.com:4000/trendscope?sslaccept=strict"

# ── Serper.dev API Key (busca Google) ──────────────────────────
# Obtenha em: https://serper.dev/dashboard
SERPER_API_KEY="sua_chave_serper_aqui"
